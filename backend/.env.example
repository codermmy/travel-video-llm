DATABASE_URL=postgresql+psycopg://localhost/travel_album_dev
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me
JWT_EXPIRES_MINUTES=43200
CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://127.0.0.1:19006,http://127.0.0.1:8081
UPLOAD_DIR=./uploads
# Optional. Admin maintenance API key (for /api/v1/admin/*).
ADMIN_API_KEY=
# Optional. Used to convert relative `/uploads/...` paths into absolute URLs for AI.
BACKEND_PUBLIC_BASE_URL=

# Clustering Configuration
# Core parameters
CLUSTERING_TIME_THRESHOLD_HOURS=48        # Base time threshold for event separation
CLUSTERING_DISTANCE_THRESHOLD_KM=50       # Base distance threshold (km)
CLUSTERING_MIN_PHOTOS_PER_EVENT=2         # P0: 从 3 降低到 2，允许更小的旅行事件

# Advanced parameters
CLUSTERING_ENABLE_SEMANTIC=true           # Enable semantic clustering (CLIP embeddings)
CLUSTERING_ENABLE_TEMPORAL_RULES=true     # Enable temporal rules post-processing
CLUSTERING_SEMANTIC_THRESHOLD=0.65        # P0: 从 0.80 降低到 0.65，提高语义聚类召回率
CLUSTERING_MERGE_SHORT_INTERVAL=180       # P0: 从 60 增加到 180 分钟 (3 小时)，容忍更长的短间隔合并
CLUSTERING_CITY_JUMP_THRESHOLD=50         # City jump threshold (km) - lowered for sensitive detection
CLUSTERING_HDBSCAN_MIN_SIZE=3             # HDBSCAN minimum cluster size (lowered for small events)
CLUSTERING_ENABLE_AI_DESCRIPTIONS=false   # Enable AI-generated photo descriptions (optional)

# Celery
CELERY_TIMEZONE=Asia/Shanghai
CELERY_TASK_TIME_LIMIT=3600
# Worker pool: macOS建议solo（避免fork触发objc崩溃），Linux生产建议prefork
CELERY_WORKER_POOL=
CELERY_WORKER_CONCURRENCY=4

# External integrations
# AI provider selection: openai | tongyi | deepseek
AI_PROVIDER=openai

# OpenAI-compatible provider (default for local/prod in this project)
OPENAI_BASE_URL=http://api.yescode.cloud/v1
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.1-codex
OPENAI_STORY_MODEL=gpt-5.1-codex
OPENAI_TIMEOUT_SECONDS=30

# DeepSeek (recommended text generation provider when cloud image analysis is disabled)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_STORY_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30

# DashScope / Tongyi (optional fallback provider)
DASHSCOPE_API_KEY=
TONGYI_API_KEY=

# AMap reverse geocoding
AMAP_API_KEY=

# SMTP email (verification / reset password)
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Aliyun OSS (recommended for public photo URLs used by AI)
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# Optional CDN/domain, e.g. https://cdn.example.com
OSS_PUBLIC_BASE_URL=
